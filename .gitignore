# Signing secrets — never commit
*.jks
android/key.properties

# Dependency folders — regenerable, never commit
node_modules/
**/node_modules/

# Stray uploads / logs / other-app copies
assets/uploads/
*.log
hs_err_pid*.log
replay_pid*.log

# Crash dumps / build junk
*.hprof
*.txt
build_log.txt
analyze_output.txt

# Design mockups — not app source
Redesign/

